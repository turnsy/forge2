{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge2.app/schemas/reference-maxes.schema.json",
  "title": "Reference Maxes",
  "description": "Athlete-specific reference max values that percentage-based workout plan sets can resolve against.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "maxes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "athleteId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "maxes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/referenceMax"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "referenceMax": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "value",
        "unit"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "exerciseName": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "value": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "kg",
            "lb"
          ]
        },
        "notes": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
