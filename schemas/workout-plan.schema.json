{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge2.app/schemas/workout-plan.schema.json",
  "title": "Workout Plan",
  "description": "Week/day structured workout plan schema that supports percentage-based and absolute load prescriptions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "weeks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "discipline": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "referenceMaxes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/referenceMax"
      }
    },
    "weeks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/week"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "repsValue": {
      "description": "Supports simple reps (5) and combined reps (3+1).",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[0-9]+(?:\\+[0-9]+)*$"
        }
      ]
    },
    "referenceMax": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "exerciseName",
        "value",
        "unit"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "exerciseName": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "value": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "kg",
            "lb"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "week": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "days"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "days": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/day"
          }
        }
      }
    },
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "code",
        "exercises"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "code": {
          "type": "string",
          "pattern": "^w[0-9]+d[0-9]+$"
        },
        "name": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "exercises": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/exercise"
          }
        }
      }
    },
    "exercise": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "prescriptions"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "notes": {
          "type": "string"
        },
        "prescriptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/prescription"
          }
        }
      }
    },
    "prescription": {
      "oneOf": [
        {
          "$ref": "#/$defs/setRepPrescription"
        },
        {
          "$ref": "#/$defs/targetPrescription"
        }
      ]
    },
    "setRepPrescription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "sets",
        "reps",
        "load"
      ],
      "properties": {
        "type": {
          "const": "set-rep"
        },
        "sets": {
          "type": "integer",
          "minimum": 1
        },
        "reps": {
          "$ref": "#/$defs/repsValue"
        },
        "load": {
          "$ref": "#/$defs/load"
        },
        "tempo": {
          "type": "string"
        },
        "restSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "targetPrescription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "goal"
      ],
      "properties": {
        "type": {
          "const": "target"
        },
        "goal": {
          "$ref": "#/$defs/goal"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "goal": {
      "oneOf": [
        {
          "$ref": "#/$defs/goalSetsReps"
        },
        {
          "$ref": "#/$defs/goalRepMax"
        },
        {
          "$ref": "#/$defs/goalText"
        }
      ]
    },
    "goalSetsReps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "sets",
        "reps"
      ],
      "properties": {
        "type": {
          "const": "sets-reps"
        },
        "sets": {
          "type": "integer",
          "minimum": 1
        },
        "reps": {
          "$ref": "#/$defs/repsValue"
        },
        "load": {
          "$ref": "#/$defs/load"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "goalRepMax": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "repMax"
      ],
      "properties": {
        "type": {
          "const": "rep-max"
        },
        "repMax": {
          "type": "integer",
          "minimum": 1
        },
        "load": {
          "$ref": "#/$defs/load"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "goalText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "text"
        },
        "text": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "load": {
      "oneOf": [
        {
          "$ref": "#/$defs/absoluteLoad"
        },
        {
          "$ref": "#/$defs/percentageLoad"
        }
      ]
    },
    "absoluteLoad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value",
        "unit"
      ],
      "properties": {
        "type": {
          "const": "absolute"
        },
        "value": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "kg",
            "lb",
            "g"
          ]
        }
      }
    },
    "percentageLoad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "unit",
        "reference",
        "operator"
      ],
      "properties": {
        "type": {
          "const": "percentage"
        },
        "unit": {
          "const": "%"
        },
        "reference": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "operator": {
          "type": "string",
          "enum": [
            "exact",
            "range",
            "at-least",
            "at-most"
          ]
        },
        "value": {
          "type": "number",
          "minimum": 0
        },
        "minValue": {
          "type": "number",
          "minimum": 0
        },
        "maxValue": {
          "type": "number",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "operator": {
                  "const": "exact"
                }
              },
              "required": [
                "value"
              ]
            },
            {
              "properties": {
                "operator": {
                  "const": "at-least"
                }
              },
              "required": [
                "value"
              ]
            },
            {
              "properties": {
                "operator": {
                  "const": "at-most"
                }
              },
              "required": [
                "value"
              ]
            },
            {
              "properties": {
                "operator": {
                  "const": "range"
                }
              },
              "required": [
                "minValue",
                "maxValue"
              ]
            }
          ]
        }
      ]
    }
  }
}
