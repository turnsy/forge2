NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: canonical site URL for auth redirects (recommended for custom domains)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Local OAuth (optional — configure in Supabase Dashboard for hosted project)
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# Plan generation (v1) — see docs/plan-generation/README.md
# Vercel AI Gateway (exact name per Vercel docs when wired)
# AI_GATEWAY_API_KEY=
# Vercel Sandbox — required for local dev (real sandbox, not mocked)
# VERCEL_OIDC_TOKEN=
# Optional: opt-in sandbox integration tests
# RUN_SANDBOX_INTEGRATION=1
