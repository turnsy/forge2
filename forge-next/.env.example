NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: canonical site URL for auth redirects (recommended for custom domains)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Local OAuth (optional — configure in Supabase Dashboard for hosted project)
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# --- Plan generation (v1) ---
# Docs: docs/plan-generation/README.md
# Storage: docs/plan-generation/supabase-draft-uploads.md

# Vercel AI Gateway — used by plan-chat (Phase 3). On Vercel deploys, OIDC may apply instead.
AI_GATEWAY_API_KEY=

# Vercel Sandbox — local dev: run `vercel link` in forge-next/, then `vercel env pull .env.local`
# OIDC (preferred on linked projects):
VERCEL_OIDC_TOKEN=
# Or manual token for CI / external machines:
# VERCEL_TOKEN=
# VERCEL_ACCESS_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=

# Optional: run real sandbox integration tests (Phase 4+)
# RUN_SANDBOX_INTEGRATION=1
